# LINE ブリッジ MCP の設定。これを .env にコピーして値を埋める。
#   cp .env.example .env
# .env は .gitignore 済み（秘密情報なのでコミットしない）。

# --- 必須 ---------------------------------------------------------------

# LINE Developers コンソール → 対象チャネル → Messaging API タブ →
# "Channel access token (long-lived)" で発行した長期トークン
LINE_CHANNEL_ACCESS_TOKEN=

# 送信先＝自分の userId（U で始まる 32 桁の16進）。get_user_id.py で取得可能。
LINE_USER_ID=

# 画像配信用の公開 HTTPS ベース URL（Tailscale Funnel のホスト）。
# 例えば: https://your-machine.your-tailnet.ts.net
LINE_PUBLIC_BASE_URL=https://your-machine.your-tailnet.ts.net

# --- 任意（通常は既定でOK） ---------------------------------------------

# 公開ディレクトリ（画像の一時置き場）。未指定ならサーバー直下の public/。
# LINE_PUBLIC_DIR=

# 静的サーバーのローカルポート。Funnel のターゲットと一致させること。
# （8765 は別プロセスが使用中だったため既定は 8910）
# LINE_STATIC_PORT=8910

# get_user_id.py の署名検証に使う（Messaging API タブの "Channel secret"）。
# get_user_id.py を使って userId を取得する場合は必須（未設定だと起動を拒否する）。
# LINE_CHANNEL_SECRET=
